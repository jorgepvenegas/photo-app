# Railway Environment Variables Template
# Copy this to .env.railway and fill in your values
# Then add these to Railway dashboard Variables tab

# Railway provides this automatically when you add PostgreSQL
# DATABASE_URL=postgresql://...

# Auth - Generate secure 32+ character strings
JWT_SECRET=change-me-to-a-secure-random-string-minimum-32-chars
SECRET_KEY=change-me-to-another-secure-random-string-minimum-32-chars

# R2 Storage - Get from Cloudflare R2 dashboard
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=photo-app
R2_PUBLIC_URL=https://<bucket>.<account>.r2.dev

# Email (Resend) - Get from resend.com
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com

# App URLs - Will be your Railway domain
# Railway provides this: https://<service-name>.up.railway.app
APP_URL=https://your-backend-url.up.railway.app
FRONTEND_URL=https://your-frontend-url.up.railway.app

# Disable debug mode in production
DEBUG=false
